#!/usr/bin/env python3
"""Notification helper for semi-autonomous agent sessions.

Generated by AgentScaffold for {{ project_name }}.
Sends notifications via the configured channel (stdout, GitHub Issues, Slack).

Usage:
    python scripts/notify.py plan_complete "Plan 042 finished successfully"
    python scripts/notify.py escalation "Risk check failed -- manual review needed"
    python scripts/notify.py approval_required "Plan 050 needs human approval"
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from urllib.error import URLError
from urllib.request import Request, urlopen

CHANNEL = "{{ config.semi_autonomous.notifications.channel }}"
SLACK_WEBHOOK_ENV = "{{ config.semi_autonomous.notifications.slack_webhook_env }}"
NOTIFY_ON = {{ config.semi_autonomous.notifications.notify_on | tojson }}


def send_stdout(event: str, message: str) -> None:
    print(f"[{event}] {message}")


def send_github_issue(event: str, message: str) -> None:
    try:
        result = subprocess.run(
            [
                "gh", "issue", "create",
                "--title", f"[{event}] {message[:80]}",
                "--body", message,
            ],
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode == 0:
            print(f"GitHub issue created: {result.stdout.strip()}")
        else:
            print(f"gh issue create failed: {result.stderr.strip()}", file=sys.stderr)
            send_stdout(event, message)
    except FileNotFoundError:
        print("gh CLI not installed -- falling back to stdout", file=sys.stderr)
        send_stdout(event, message)
    except subprocess.TimeoutExpired:
        print("gh issue create timed out -- falling back to stdout", file=sys.stderr)
        send_stdout(event, message)


def send_slack(event: str, message: str) -> None:
    webhook_url = os.environ.get(SLACK_WEBHOOK_ENV)
    if not webhook_url:
        print(
            f"Slack webhook env var {SLACK_WEBHOOK_ENV} not set -- falling back to stdout",
            file=sys.stderr,
        )
        send_stdout(event, message)
        return

    payload = json.dumps({"text": f"*[{event}]* {message}"}).encode()
    req = Request(webhook_url, data=payload, headers={"Content-Type": "application/json"})

    try:
        with urlopen(req, timeout=15):
            print("Slack notification sent")
    except (URLError, OSError) as exc:
        print(f"Slack notification failed: {exc} -- falling back to stdout", file=sys.stderr)
        send_stdout(event, message)


SENDERS = {
    "stdout": send_stdout,
    "github_issue": send_github_issue,
    "slack": send_slack,
}


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Send a notification for an agent session event.",
    )
    parser.add_argument(
        "event",
        help="Event name (e.g. plan_complete, escalation, validation_failure, approval_required).",
    )
    parser.add_argument("message", help="Notification body text.")
    parser.add_argument(
        "--channel",
        default=CHANNEL,
        choices=sorted(SENDERS),
        help=f"Notification channel (default: {CHANNEL}).",
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Send even if event is not in the configured notify_on list.",
    )
    args = parser.parse_args()

    if not args.force and args.event not in NOTIFY_ON:
        print(
            f"Event '{args.event}' not in notify_on list {NOTIFY_ON}. "
            "Use --force to send anyway.",
            file=sys.stderr,
        )
        raise SystemExit(1)

    sender = SENDERS.get(args.channel, send_stdout)
    sender(args.event, args.message)


if __name__ == "__main__":
    main()
