# scaffold.yaml -- {{ project_name }}
# Generated by AgentScaffold on {{ date }}
#
# This file configures the AgentScaffold framework for your project.
# Regenerate agent files after editing: scaffold agents generate

framework:
  version: "1.0"
  project_name: "{{ project_name }}"
  architecture_layers: {{ architecture_layers }}

profile: {{ profile }}
rigor: {{ rigor }}

{% if domains %}
domains:
{% for d in domains %}
  - {{ d }}
{% endfor %}
{% else %}
domains: []
{% endif %}

gates:
  draft_to_review:
    plan_lint: true
{% if rigor == "minimal" %}
    architecture_layer_check: false
{% else %}
    architecture_layer_check: true
{% endif %}

  review_to_ready:
{% if rigor == "minimal" %}
    devils_advocate: false
    expansion_review: false
    spike_for_high_uncertainty: false
    interface_contracts: false
    security_review: false
{% elif rigor == "strict" %}
    devils_advocate: true
    expansion_review: true
    spike_for_high_uncertainty: true
    interface_contracts: true
    security_review: true
{% else %}
    devils_advocate: true
    expansion_review: true
    spike_for_high_uncertainty: true
    interface_contracts: true
    security_review: true
{% endif %}
    domain_reviews: []

  ready_to_in_progress:
{% if rigor == "minimal" %}
    review_checklist: false
    approval_gates: false
    interactive_gate: false
{% elif rigor == "strict" %}
    review_checklist: true
    approval_gates: true
    interactive_gate: true
{% else %}
    review_checklist: true
    approval_gates: true
    interactive_gate: true
{% endif %}

  in_progress_to_complete:
    all_steps_checked: true
    validation_commands: true
    tests_pass: true
{% if rigor == "minimal" %}
    retrospective: false
    domain_implementation_review: false
{% elif rigor == "strict" %}
    retrospective: true
    domain_implementation_review: true
{% else %}
    retrospective: true
    domain_implementation_review: false
{% endif %}

approval_required:
  breaking_changes: true
  security_sensitive: true
  data_migrations: true
  infrastructure: true
  external_apis: true

standards:
  core:
    - errors
    - logging
    - config
    - testing
  domain: []

prohibitions:
  emojis: false
  patterns: []

agents:
  agents_md: true
  cursor_rules: true

semi_autonomous:
{% if profile == "semi_autonomous" %}
  enabled: true
{% else %}
  enabled: false
{% endif %}
  session_tracking: true
  context_handoff: true
  safety:
    read_only_paths:
      - "docs/ai/system_architecture.md"
      - "scaffold.yaml"
      - ".github/"
    require_approval_paths:
      - "infra/"
      - "docs/security/"
  notifications:
    enabled: true
    channel: github_issue
    notify_on:
      - plan_complete
      - escalation
      - validation_failure
      - approval_required
  cautious_execution:
    max_fix_attempts: 2
    max_new_files_before_escalation: 5

task_runner:
  justfile: true
  makefile: true

ci:
  provider: github
  security_scanning: true
  study_lint: true
{% if rigor == "strict" %}
  plan_lint: true
{% else %}
  plan_lint: false
{% endif %}
{% if profile == "semi_autonomous" %}
  semi_autonomous_pr_checks: true
{% else %}
  semi_autonomous_pr_checks: false
{% endif %}

import:
  conversation_dir: "data/conversations"
