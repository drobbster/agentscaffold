## Unit Test Patterns

### Test Class Organization

```python
# tests/unit/services/test_processor.py

import pytest
from {{ project_name }}.services.processor import BatchProcessor


class TestBatchProcessor:
    """Tests for BatchProcessor item processing."""
    
    @pytest.fixture
    def processor(self):
        """Create processor with default parameters."""
        return BatchProcessor(batch_size=10, timeout=30)
    
    @pytest.fixture
    def sample_items(self):
        """Create sample input items."""
        return [{"id": i, "value": f"item_{i}"} for i in range(50)]
    
    # --- Happy Path Tests ---
    
    def test_processes_all_items_in_batch(self, processor, sample_items):
        """Should return results for all input items."""
        results = processor.process(sample_items)
        
        assert len(results) == len(sample_items)
        assert all(r["status"] == "complete" for r in results)
    
    def test_result_contains_required_fields(self, processor, sample_items):
        """All results must contain id, status, and timestamp."""
        results = processor.process(sample_items)
        
        for result in results:
            assert "id" in result
            assert "status" in result
            assert "timestamp" in result
    
    # --- Edge Cases ---
    
    def test_returns_empty_for_empty_input(self, processor):
        """Should return empty list for empty input."""
        results = processor.process([])
        
        assert results == []
    
    def test_handles_single_item(self, processor):
        """Should handle single-item input correctly."""
        results = processor.process([{"id": 1, "value": "solo"}])
        
        assert len(results) == 1
    
    # --- Error Cases ---
    
    def test_raises_on_missing_required_fields(self, processor):
        """Should raise ValueError when required fields missing."""
        bad_items = [{"wrong_field": "value"}]
        
        with pytest.raises(ValueError, match="Missing required field"):
            processor.process(bad_items)
    
    # --- Property Tests ---
    
    def test_name_property(self, processor):
        """Processor name should reflect configuration."""
        assert processor.name == "batch_processor"
    
    def test_get_params_returns_all_parameters(self, processor):
        """get_params should return all constructor arguments."""
        params = processor.get_params()
        
        assert "batch_size" in params
        assert "timeout" in params
        assert params["batch_size"] == 10
```

### Naming Convention

```python
# Pattern: test_{action}_{context}_{expected_outcome}

def test_processes_all_items_in_batch(self):
    """Should return results for all input items."""
    
def test_raises_on_missing_required_fields(self):
    """Should raise ValueError when required fields missing."""
    
def test_returns_empty_for_empty_input(self):
    """Should return empty list for empty input."""
```

