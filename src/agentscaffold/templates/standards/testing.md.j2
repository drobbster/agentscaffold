## Mocking External Dependencies

### Pattern: Mock at Boundary

```python
# tests/unit/data/test_handlers.py

from unittest.mock import Mock, patch

def test_fetches_data_from_primary_source(mocker):
    """Should use primary source when available."""
    mock_source = Mock()
    mock_source.fetch.return_value = {"items": [...]}
    
    handler = DataHandler(primary_source=mock_source)
    data = handler.fetch_data("users", page=1)
    
    mock_source.fetch.assert_called_once_with("users", page=1)


def test_falls_back_on_primary_failure(mocker):
    """Should use fallback when primary raises."""
    mock_primary = Mock()
    mock_primary.fetch.side_effect = ConnectionError()
    
    mock_fallback = Mock()
    mock_fallback.fetch.return_value = {"items": [...]}
    
    handler = DataHandler(primary_source=mock_primary, fallback_source=mock_fallback)
    data = handler.fetch_data("users", page=1)
    
    mock_fallback.fetch.assert_called_once()
```

