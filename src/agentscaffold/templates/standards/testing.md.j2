## Fixtures

### Shared Fixtures in conftest.py

```python
# tests/conftest.py

import pytest
from datetime import date


@pytest.fixture
def sample_records():
    """Generate sample records for testing."""
    return [
        {"id": i, "name": f"item_{i}", "value": i * 10.5, "active": True}
        for i in range(100)
    ]


@pytest.fixture
def mock_api_client(mocker):
    """Create mock API client."""
    client = mocker.Mock()
    client.fetch.return_value = {"status": "ok", "data": []}
    return client


@pytest.fixture
def temp_cache_dir(tmp_path):
    """Create temporary directory for cache tests."""
    cache_dir = tmp_path / "cache"
    cache_dir.mkdir()
    return cache_dir
```

### Fixture Scopes

```python
@pytest.fixture(scope="session")
def expensive_setup():
    """Run once per test session (e.g., database setup)."""
    db = create_test_database()
    yield db
    db.cleanup()


@pytest.fixture(scope="module")
def module_level_data():
    """Run once per test module."""
    return load_large_dataset()


@pytest.fixture(scope="function")  # Default
def per_test_fixture():
    """Fresh instance for each test."""
    return SomeClass()
```

