## Configuration Testing

```python
import pytest
from unittest.mock import patch

def test_config_loads_from_env():
    with patch.dict("os.environ", {"SERVICE_API_KEY": "test-key"}):  # pragma: allowlist secret
        config = ServiceConfig()
        assert config.api_key == "test-key"  # pragma: allowlist secret


def test_config_validates_timeout():
    with pytest.raises(ValueError, match="must be in"):
        ServiceConfig(api_key="key", timeout_seconds=999)  # pragma: allowlist secret


def test_config_requires_api_key():
    with pytest.raises(ValueError, match="api_key"):
        ServiceConfig()  # Missing required field
```

