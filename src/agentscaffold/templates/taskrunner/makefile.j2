# {{ project_name }} -- Task Runner
# Generated by AgentScaffold

.PHONY: lint-plans plan-status check-retros validate study-lint metrics \
        agents-generate cursor-setup lint format test test-cov ci-setup{% if config.semi_autonomous.enabled %} \
        validate-safety validate-session{% endif %}

# Framework commands
lint-plans:
	scaffold plan lint

plan-status:
	scaffold plan status

check-retros:
	scaffold retro check

validate:
	scaffold validate

study-lint:
	scaffold study lint

metrics:
	scaffold metrics

# Regenerate agent configs
agents-generate:
	scaffold agents generate

cursor-setup:
	scaffold agents cursor

# Quality commands
lint:
	ruff check .

format:
	ruff format .

test:
	pytest -q

test-cov:
	pytest --cov -q

# CI setup
ci-setup:
	scaffold ci setup
{% if config.semi_autonomous.enabled %}

# Semi-autonomous validation
validate-safety:
	scaffold validate --check-safety-boundaries

validate-session:
	scaffold validate --check-session-summary
{% endif %}
