## Testing Idempotency

### Required Tests

```python
def test_pipeline_is_idempotent():
    """Running pipeline twice produces same result."""
    run_pipeline(date="2026-01-15")
    result_1 = read_output(date="2026-01-15")

    run_pipeline(date="2026-01-15")
    result_2 = read_output(date="2026-01-15")

    assert_dataframes_equal(result_1, result_2)


def test_no_duplicates_on_retry():
    """Retrying after partial failure does not duplicate."""
    run_pipeline(date="2026-01-15")
    count_1 = count_records(date="2026-01-15")

    run_pipeline(date="2026-01-15")  # Retry
    count_2 = count_records(date="2026-01-15")

    assert count_1 == count_2
```

